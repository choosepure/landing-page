{
  "expo": {
    "name": "ChoosePure",
    "slug": "choosepure",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "choosepure",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.choosepure.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "package": "in.choosepure.app",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ChoosePure to access your camera to scan product barcodes",
          "recordAudioAndroid": false
        }
      ],
      "./plugins/withRazorpay",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f735d7c1-0935-46b3-ac19-5b0c945db8db"
      }
    }
  }
}
