{
  "expo": {
    "name": "ChoosePure",
    "slug": "choosepure",
    "version": "2.1.0",
    "orientation": "portrait",
    "scheme": "choosepure",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "in.choosepure.app",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "package": "in.choosepure.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.CAMERA"
      ],
      "versionCode": 20
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ChoosePure to access your camera to scan product barcodes",
          "recordAudioAndroid": false
        }
      ],
      "./plugins/withRazorpay",
      "./plugins/withAdiRegistration",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25",
            "newArchEnabled": false,
            "targetSdkVersion": 35,
            "compileSdkVersion": 35
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      "@react-native-firebase/crashlytics",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "f735d7c1-0935-46b3-ac19-5b0c945db8db"
      }
    }
  }
}
